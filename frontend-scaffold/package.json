{
  "name": "stellar-tipz-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Stellar Tipz - Decentralized tipping platform frontend",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:a11y": "vitest run src/test/accessibility.test.tsx --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright  test --headed",
    "analyze": "npm run build && node scripts/analyze-bundle.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Akanimoh12/Stellar-Tipz.git"
  },
  "prettier": "@stellar/prettier-config",
  "keywords": [],
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@stellar/prettier-config": "^1.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.6.4",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^2.8.8",
    "sass": "^1.62.1",
    "tailwindcss": "^3.4.18",
    "terser": "^5.48.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.3.0",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@emotion/is-prop-valid": "^1.4.0",
    "@stellar/freighter-api": "1.7.1",
    "@stellar/stellar-sdk": "^11.3.0",
    "bignumber.js": "^9.1.1",
    "canvas-confetti": "^1.9.3",
    "framer-motion": "^12.23.24",
    "fuse.js": "^7.3.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.553.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.5",
    "recharts": "^2.15.4",
    "zustand": "^5.0.0"
  }
}
